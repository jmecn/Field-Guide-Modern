# CI runtime settings. Release-backed mods: leave *_VERSION empty = latest semver GitHub tag.

JAVA_VERSION=17

MC_VERSION=1.20.1
MC_ASSET_INDEX=5
FORGE_BUILD=47.4.13

HMC_VERSION=2.9.0
MODPACK_DIR=Modpack-Modern
MODPACK_REPO=https://github.com/TerraFirmaGreg-Team/Modpack-Modern.git

# GitHub Release jars (jmecn/*). Empty = resolve latest tag at CI (ci/run.sh).
FGE_REPO=jmecn/field-guide-export
FGE_VERSION=
MWE_REPO=jmecn/minecraft-web-export
MWE_VERSION=

# Export locales: derived at CI from Language enum (ci/run.sh export-languages)
# → -Dfieldguide.exportLanguages=... on the game JVM

EXPORT_WARMUP_TICKS=100
EXPORT_WORLD_DELAY_TICKS=600
EXPORT_TIMEOUT_SECONDS=7200

# Export bundle cache for deploy: key ${EXPORT_CACHE_KEY_PREFIX}-<bundle_id>-<export_fingerprint>
# export_fingerprint = sha256(modpack:fge:mwe) first 8 hex chars
# Paths: export-meta/ + guide-export-<bundle_id>.tar.gz at workspace root.
EXPORT_CACHE_KEY_PREFIX=fge-export

# Legacy artifact name (local fetch-bundle debugging only).
EXPORT_ARTIFACT_NAME=field-guide

# minecraft-web-export output root (guide-export/ + emi/ siblings)
EXPORT_ROOT_DIR=export
GUIDE_SUBDIR=guide-export
SITE_OUTPUT_DIR=output

# GitHub Release tar for Wiki aggregation (tag + contentHash are written to build.json).
SITE_RELEASE_ASSET_NAME=field-guide-site.tar.gz
SITE_RELEASE_HASH_LENGTH=7

# Published build gate: last successful deploy versions at this URL.
# Empty = https://<owner>.github.io/<repo>/build.json from GITHUB_REPOSITORY.
BUILD_JSON_URL=

# EMI slot / tag popover links → ?lang=&item= or &tag= on this base (override when domain moves)
RECIPE_BOOK_BASE_URL=https://terrafirmagreg-team.github.io/RecipeBook-Modern/

RUNNER_HOME=/home/runner
